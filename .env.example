APP_NAME="Centro de Aplicaciones TIC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# --- Producción (Apache /repositorio) ---
# APP_URL=http://192.168.61.27/repositorio
# ASSET_URL=http://192.168.61.27/repositorio
# SESSION_PATH=/repositorio
# VITE_APP_BASE=/repositorio
# VITE_BASE_PATH=/repositorio/build/

# --- Desarrollo local (php artisan serve) ---
APP_URL=http://127.0.0.1:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=repositorio_apps
DB_USERNAME=repositorio
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=127.0.0.1:8000,localhost,127.0.0.1

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Límite de la app: 2097152 KB = 2 GB (archivos ~358 MB o más pesados)
REPOSITORIO_MAX_UPLOAD_KB=2097152
# Historial de instaladores (total: activa + archivadas)
REPOSITORIO_DEFAULT_MAX_VERSIONS=5
REPOSITORIO_MAX_VERSIONS_LIMIT=20

VITE_APP_NAME="${APP_NAME}"
VITE_APP_BASE=
VITE_BASE_PATH=/build/
