# Copiar a .env en el servidor: cp deploy/.env.production.example .env
# Luego: php artisan key:generate

APP_NAME="Centro de Aplicaciones TIC"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://192.168.61.27/repositorio
ASSET_URL=http://192.168.61.27/repositorio

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=repositorio_apps
DB_USERNAME=repositorio
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/repositorio
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=192.168.61.27

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REPOSITORIO_MAX_UPLOAD_KB=2097152
REPOSITORIO_DEFAULT_MAX_VERSIONS=5
REPOSITORIO_MAX_VERSIONS_LIMIT=20

VITE_APP_NAME="${APP_NAME}"
VITE_APP_BASE=/repositorio
VITE_BASE_PATH=/repositorio/build/
